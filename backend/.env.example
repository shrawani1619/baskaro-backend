PORT=4000

# Option A (recommended): full Mongo URI
MONGODB_URI=mongodb://127.0.0.1:27017/baskaro

# Option B: build from individual env vars (use if you don't want to store full URI)
# MONGO_HOST=127.0.0.1
# MONGO_PORT=27017
# MONGO_DB=baskaro
# MONGO_USER=
# MONGO_PASS=
# MONGO_AUTH_SOURCE=admin
# MONGO_TLS=false

JWT_SECRET=dev-secret

# Frontend dev origin examples:
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_ORIGIN=*

